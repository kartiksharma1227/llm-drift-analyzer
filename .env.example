# LLM Behavioral Drift Analyzer - Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# Cloud API Keys (for API-based providers)
# ============================================

# OpenAI API Key (required for GPT-4 models and evaluation)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (required for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Mistral API Key (required for Mixtral models)
MISTRAL_API_KEY=your_mistral_api_key_here

# ============================================
# Local/Offline Models (Ollama)
# ============================================

# Ollama server URL (default: http://localhost:11434)
# No API key required for local Ollama server
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# General Configuration
# ============================================

# Optional: Default model for evaluation (uses GPT-4 by default)
# For offline evaluation, you can use: EVALUATOR_MODEL=llama3
EVALUATOR_MODEL=gpt-4

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Output directory for reports
OUTPUT_DIR=output

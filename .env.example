# LLM Behavioral Drift Analyzer - Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# Cloud API Keys (for API-based providers)
# ============================================

# OpenAI API Key (required for GPT-4 models and cloud evaluation)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (required for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Mistral API Key (required for Mixtral models via API)
MISTRAL_API_KEY=your_mistral_api_key_here

# ============================================
# Local/Offline Models (Ollama)
# ============================================

# Ollama server URL (default: http://localhost:11434)
# No API key required for local Ollama server
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# Evaluation Configuration (Judge Model)
# ============================================
# The evaluator scores LLM responses for instruction adherence,
# factuality, and tone. You can use either OpenAI (GPT-4) or
# Ollama (local models) for evaluation.

# Evaluator provider: "openai" or "ollama"
# - openai: Uses GPT-4 for high-quality evaluation (requires API key, costs money)
# - ollama: Uses local models for FREE evaluation (requires Ollama server running)
EVALUATOR_PROVIDER=openai

# Model to use for evaluation
# For OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# For Ollama: llama3, mistral, mixtral, etc.
EVALUATOR_MODEL=gpt-4

# ============================================
# Fully Offline Configuration Example
# ============================================
# To run completely offline without any API costs:
#
# EVALUATOR_PROVIDER=ollama
# EVALUATOR_MODEL=llama3
#
# Then use: python main.py analyze --provider ollama --models llama3 mistral
#
# This will:
# 1. Query local Ollama models (no API costs)
# 2. Evaluate responses using local Ollama models (no API costs)

# ============================================
# General Configuration
# ============================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Output directory for reports and results
OUTPUT_DIR=output
